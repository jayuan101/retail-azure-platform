# Azure credentials (use Azure free account)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Azure Storage (free 5GB tier)
AZURE_STORAGE_ACCOUNT=retaildatalake
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_CONTAINER_BRONZE=bronze
AZURE_CONTAINER_SILVER=silver
AZURE_CONTAINER_GOLD=gold

# Azure Event Hubs (Basic tier - free namespace)
EVENT_HUB_NAMESPACE=retail-eventhub-ns
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://retail-eventhub-ns.servicebus.windows.net/...
EVENT_HUB_POS=pos-events
EVENT_HUB_INVENTORY=inventory-events
EVENT_HUB_ECOMMERCE=ecommerce-events

# Local Kafka (Docker)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_POS=retail.pos.events
KAFKA_TOPIC_INVENTORY=retail.inventory.events
KAFKA_TOPIC_ECOMMERCE=retail.ecommerce.events
KAFKA_CONSUMER_GROUP=retail-consumer-group

# Databricks Community Edition
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-token

# Azure Functions
FUNCTIONS_WORKER_RUNTIME=python
AzureWebJobsStorage=UseDevelopmentStorage=true

# Local dev
USE_LOCAL_KAFKA=true
USE_LOCAL_STORAGE=true
LOCAL_DATA_PATH=./data
LOG_LEVEL=INFO
